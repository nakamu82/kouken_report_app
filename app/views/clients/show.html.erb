      <th>種類</th>
      <th>床面積（㎡）</th>
      <th>備考（現状、持分等）</th>
      <th>資料の有無</th>
      <th>最終確認日</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% @client.real_estates.select{|estate| estate.estate_type == "建物" }.each do |real_estate| %>      <tr>
