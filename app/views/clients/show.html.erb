<h1><%= @client.name %>さんの情報</h1>

<div class="card">

  <%= link_to "被後見人情報の編集", edit_client_path(@client), class: "btn" %>

  <div class="row">
    <span class="label">名前</span>
    <span class="value"><%= @client.name %></span>
  </div>

  <div class="row">
    <span class="label">生年月日</span>
    <span class="value"><%= @client.birthdate.strftime("%Y年%m月%d日") if @client.birthdate %></span>
  </div>

  <div class="row">
    <span class="label">住所</span>
    <span class="value"><%= @client.address %></span>
  </div>

  <div class="row">
    <span class="label">事件番号</span>
    <span class="value"><%= @client.case_number %></span>
  </div>

</div>

<hr>

<h2>預貯金・現金</h2>
<%= link_to "追加", new_client_deposit_path(@client), class: "btn" %>

<table>
  <thead>
    <tr>
      <th>預貯金の種類</th>
      <th>金融機関の名称</th>
      <th>支店名</th>
      <th>口座種別</th>
      <th>口座番号</th>
      <th>残高（円）</th>
      <th>管理者</th>
      <th>資料の有無</th>
      <th>最終確認日</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
  <% @client.deposits.each do |deposit| %>
    <tr>
      <td><%= deposit.deposit_type %></td>
      <td><%= deposit.bank_name %></td>
      <td><%= deposit.branch_name %></td>
      <td><%= deposit.account_type %></td>
      <td><%= deposit.account_number %></td>
      <td><%= deposit.balance %></td>
      <td><%= deposit.manager %></td>
      <td><%= deposit.has_document ? "☑" : "□" %></td>
      <td><%= deposit.last_checked_on %></td>
      <td>
        <%= link_to "編集", edit_client_deposit_path(@client, deposit), class: "btn" %>
        <%= link_to "削除", client_deposit_path(@client, deposit),
            data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
            class: "btn" %>
      </td>
    </tr>
    <% end %>
  </tbody>
</table>

<hr>

<h2>有価証券等</h2>
<%= link_to "追加", new_client_security_path(@client), class: "btn" %>

<table>
  <thead>
    <tr>
      <th>種類</th>
      <th>銘柄名</th>
      <th>数量</th>
      <th>額面金額</th>
      <th>評価額</th>
      <th>管理者</th>
      <th>資料の有無</th>
      <th>最終確認日</th>
      <th>操作</th>
    </tr>
  </thead>

  <tbody>
    <% @client.securities.each do |security| %>
      <tr>
        <td><%= security.security_kind %></td>
        <td><%= security.security_name %></td>
        <td><%= "#{security.quantity} #{security.unit}" %></td>
        <td><%= security.face_value %></td>
        <td><%= security.amount %></td>
        <td><%= security.manager %></td>
        <td><%= security.has_document ? "☑" : "□" %></td>
        <td><%= security.security_last_checked_on %></td>
        <td>
          <%= link_to "編集", edit_client_security_path(@client, security), class:"btn" %> 
          <%= link_to "削除", client_security_path(@client, security),
                method: :delete,
                data: { confirm: "本当に削除しますか？" },
                class:"btn" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<hr>

<h2>生命保険・損害保険等</h2>
<%= link_to "追加", new_client_insurance_path(@client), class: "btn" %>

<table>
  <thead>
    <tr>
      <th>保険会社</th>
      <th>保険の種類</th>
      <th>証書番号</th>
      <th>保険金額（円）</th>
      <th>契約者</th>
      <th>受取人</th>
      <th>資料の有無</th>
      <th>最終確認日</th>
      <th>操作</th>
    <tr>
  </thead>

  <tbody>
    <% @client.insurances.each do |insurance| %>
      <tr>
        <td><%= insurance.insurance_company %></td>
        <td><%= insurance.insurance_kind %></td>
        <td><%= insurance.policy_number %></td>
        <td><%= insurance.amount %>円</td>
        <td><%= insurance.contractor %></td>
        <td><%= insurance.beneficiary %></td>
        <td><%= insurance.has_document ? "☑" : "□" %></td>
        <td><%= insurance.last_checked_on %></td>
        <td>
          <%= link_to "編集", edit_client_insurance_path(@client, insurance), class: "btn" %>
          <%= link_to "削除", client_path(@client),
              data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
              class: "btn" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<hr>

<h2>不動産（土地）</h2>
<%= link_to "追加", new_client_real_estate_path(@client), class: "btn" %>

<table>
  <thead>
    <tr>
      <th>所在</th>
      <th>地番</th>
      <th>地目</th>
      <th>地積（㎡）</th>
      <th>備考（現状、持分等）</th>
      <th>資料の有無</th>
      <th>最終確認日</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
<% @client.real_estates.select {|estate| estate.estate_type == "土地"} .each do |real_estate| %>      <tr>
        <td><%= real_estate.address %></td>
        <td><%= real_estate.lot_number %></td>
        <td><%= real_estate.land_category %></td>
        <td><%= real_estate.area %></td>
        <td><%= real_estate.note %></td>
        <td><%= real_estate.has_document ? "☑" : "□" %></td>
        <td><%= real_estate.last_checked_on %></td>
        <td>
          <%= link_to "編集", edit_client_real_estate_path(@client, real_estate), class: "btn" %>
          <%= link_to "削除", client_real_estate_path(@client, real_estate),
                data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
                class: "btn" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

