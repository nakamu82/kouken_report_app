        <td><%= real_estate.land_category %></td>
        <td><%= real_estate.area %></td>
        <td><%= real_estate.note %></td>
        <td><%= real_estate.has_document ? "☑" : "□" %></td>
        <td><%= real_estate.last_checked_on %></td>
        <td>
          <%= link_to "編集", edit_client_real_estate_path(@client, real_estate), class: "btn" %>
             <%= link_to "削除", client_real_estate_path(@client, real_estate),
                  data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
                  class: "btn" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<hr>

<h2>債権</h2>
