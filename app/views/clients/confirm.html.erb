<h1>被後見人の詳細</h1>

<p>
  <strong>名前:</strong>
  <%= @client.name %>
</p>

<p>
  <strong>生年月日:</strong>
  <%= @client.birthdate.strftime("%Y年%m月%d日") if @client.birthdate %>
</p>

<p>
  <strong>住所:</strong>
  <%= @client.address %>
</p>

<p>
  <strong>事件番号:</strong>
  <%= @client.case_number %>
</p>

<%= link_to '一覧に戻る', clients_path %>
