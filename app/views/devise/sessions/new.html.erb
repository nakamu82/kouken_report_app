<h1>ログイン</h1>

<div class="container">

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="field">
      <p><%= f.label :email %><i>メールアドレス</i></p>
      <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
    </div>

    <div class="field">
      <p><%= f.label :password %><i>パスワード</i></p>
      <p><%= f.password_field :password, autocomplete: "current-password" %></p>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="field"><i>パスワードを記憶しますか？</i>
        <p><%= f.check_box :remember_me %></p>
        <p><%= f.label :remember_me %></p>
      </div>
    <% end %>

    <div class="actions">
      <%= f.submit "Log in" %>
    </div>
  <% end %>
</div>


    <%= button_to "> ゲストログイン",
          users_guest_sign_in_path,
          method: :post,
          data: { turbo: false },
          class: "btn btn-glay" %>
    <%= render "devise/shared/links" %>


