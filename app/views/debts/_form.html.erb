<%= form_with(model: [@client, @debt]) do |form| %>

  <div>
    <%= form.label :creditor_name, "債権者名（支払先）" %>
    <%= form.text_field :creditor_name %>
  </div>

  <div>
    <%= form.label :content, "負債の内容" %>
    <%= form.text_field :content %>
  </div>

  <div>
    <%= form.label :amount, "残額（円）" %>
    <%= form.number_field :amount %>
  </div>

  <div>
    <%= form.label :monthly_payment, "返済月額（円）" %>
    <%= form.number_field :monthly_payment %>
  </div>

  <div>
    <%= form.label :has_document, "資料の有無" %>
    <%= form.check_box :has_document %>
  </div>

  <div>
    <%= form.label :last_checked_on, "最終確認日" %>
    <%= form.date_field :last_checked_on %>
  </div>

  <div>
    <%= form.submit "登録する" %>
    <%= link_to "戻る", client_path(@client), class: "btn btn-glay" %> 
  </div>

<% end %>